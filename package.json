{
  "name": "opennord",
  "version": "0.0.1",
  "private": false,
  "license": "AGPL-3.0-or-later",
  "description": "Open, AI-native companion for the Nord Stage 4 — browse, share and visualize programs, and (experimental) talk to your Nord directly.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src && stylelint \"src/**/*.css\"",
    "lint:fix": "eslint src --fix && stylelint \"src/**/*.css\" --fix",
    "fixtures:scan": "vitest run src/lib/clavia/fixtures-scan.test.ts",
    "cap:sync": "cap sync"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@capacitor/core": "^8.4.0",
    "@tanstack/react-router": "^1.170.16",
    "ai": "^6.0.206",
    "comlink": "^4.4.2",
    "fflate": "^0.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/w3c-web-usb": "^1.0.14",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "fast-xml-parser": "^5.9.0",
    "jsdom": "^29.1.1",
    "stylelint": "^17.13.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
